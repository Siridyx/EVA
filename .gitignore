# Eva data/ — protège tout sauf structure
# Racine data/ (historique)
data/logs/*
data/memory/*
data/cache/*
data/prompts/*
data/dumps/*
*.log

# Garde la structure data/ racine
!data/logs/.gitkeep
!data/memory/.gitkeep
!data/cache/.gitkeep
!data/prompts/.gitkeep
!data/dumps/.gitkeep

# eva/data/ — conversations, vecteurs, cache LLM (runtime, non versionné)
eva/data/**
!eva/data/**/.gitkeep

